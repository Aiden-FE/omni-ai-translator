{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["chrome", "wxt/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "env.d.ts",
    ".wxt/types/**/*.d.ts",
    "entrypoints/**/*",
    "shared/**/*",
    "wxt.config.ts"
  ],
  "exclude": ["node_modules", ".output", "e2e", "playwright.config.ts", "vitest.config.ts", "shared/**/*.test.ts"]
}
